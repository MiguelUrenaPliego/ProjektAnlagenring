# ==========================================================
# ABsurveys/ is a normal tracked folder in this repo (no
# separate remote/submodule) — its own .gitignore (models/,
# .venv/, frontend/node_modules/, etc.) still applies on top
# of the generic rules below.
# ==========================================================

# ==========================================================
# routing/ heavy geodata — not source, regenerated by
# routing/main.py from OSM/population downloads. routing/
# itself is a normal tracked folder in this repo (no separate
# remote), just these specific data/cache subfolders are too
# large to commit.
# ==========================================================
/routing/data/
/routing/streets/
/routing/population/
/routing/routing_egines/
/routing/notebooks/*.gpkg

# ==========================================================
# Reference material (papers, not project source)
# ==========================================================
/references/

# ==========================================================
# Python
# ==========================================================
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
wheels/
*.egg-info/

# Virtual environments
.venv/
venv/
env/
ENV/

# Python caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# ==========================================================
# Node / npm
# ==========================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================================
# OS / editor cruft (but keep .vscode/settings.json — see below)
# ==========================================================
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/settings.json

# Claude Code project state (local, per-machine)
.claude/
**/.claude/

# ==========================================================
# Misc temp/cache
# ==========================================================
*.log
*.tmp
.cache/

# Scratch report notes at repo root (not the report/ LaTeX project)
/report.md

**/orientation/**

report_part_Joty.pdf 

Projekt_3_Grünraum.pdf